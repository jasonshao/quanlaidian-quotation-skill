{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuoteAudit",
  "type": "object",
  "required": ["status", "issues", "suggested_adjustments", "chat_summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "message"],
        "properties": {
          "type": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "suggested_adjustments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "action", "value"],
        "properties": {
          "field": { "type": "string" },
          "action": { "type": "string" },
          "value": {}
        }
      }
    },
    "chat_summary": { "type": "string" }
  }
}
